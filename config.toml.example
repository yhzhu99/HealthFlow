# HealthFlow Configuration

[llm.openai]
base_url = "https://api.openai.com/v1"
api_key = "YOUR_OPENAI_API_KEY"
model_name = "gpt-4-turbo-preview"
input_cost_per_million_tokens = 0.0
output_cost_per_million_tokens = 0.0

[llm.deepseek-chat]
base_url = "https://api.deepseek.com/v1"
api_key = "YOUR_DEEPSEEK_API_KEY"
model_name = "deepseek-chat"
input_cost_per_million_tokens = 0.0
output_cost_per_million_tokens = 0.0

[llm.deepseek-reasoner]
base_url = "https://api.deepseek.com/v1"
api_key = "YOUR_DEEPSEEK_API_KEY"
model_name = "deepseek-reasoner"
input_cost_per_million_tokens = 0.0
output_cost_per_million_tokens = 0.0

[llm_roles]
planner = "deepseek-reasoner"
evaluator = "openai"
reflector = "deepseek-chat"

# --- Executor Configuration ---
[executor]
active_backend = "claude_code"
prompt_file_name = "executor_prompt.md"

[executor.backends.claude_code]
binary = "claude"
args = ["--dangerously-skip-permissions", "--print"]
prompt_mode = "append"
timeout_seconds = 900

[executor.backends.opencode]
binary = "opencode"
args = []
prompt_mode = "append"
timeout_seconds = 900

[executor.backends.pi]
binary = "pi"
args = []
prompt_mode = "append"
timeout_seconds = 900

# --- System Configuration ---
[system]
max_attempts = 3
workspace_dir = "workspace/tasks"
shell = "/usr/bin/zsh"

# --- Memory Configuration ---
[memory]
mode = "accumulate_eval" # accumulate_eval | frozen_train | reset
retrieve_k = 6
strategy_k = 3
failure_k = 2
dataset_k = 1
writeback_on_failure = true

# --- Optional EHR Overlay Configuration ---
[ehr]
enable_profile = true
enable_risk_checks = true
max_preview_rows = 3

# --- Verification Configuration ---
[verification]
require_verifier_pass = true
required_report_sections = ["Task Summary", "Data Profile", "Method", "Verification", "Limitations"]

# --- Evaluation Configuration ---
[evaluation]
success_threshold = 6.0

# --- Logging Configuration ---
[logging]
log_level = "INFO"
log_file = "healthflow.log"
